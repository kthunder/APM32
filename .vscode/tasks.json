{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build All",
            "command": "cmake -S . -B build -G Ninja ; cmake --build build -j12 --target all_firmware",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "hide": false
        },
        {
            "type": "shell",
            "label": "Build Boot",
            "command": "cmake -S . -B build -G Ninja ; cmake --build build -j12 --target boot",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "hide": false
        },
        {
            "type": "shell",
            "label": "Build App",
            "command": "cmake -S . -B build -G Ninja ; cmake --build build -j12 --target app_fw",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "hide": false
        },
        {
            "type": "shell",
            "label": "Download Boot",
            "command": "openocd -f interface/cmsis-dap.cfg -f target/geehy/apm32f4x.cfg -c'program ./build/boot.elf reset exit' ",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "dependsOn": ["Build Boot"]
        },
        {
            "type": "shell",
            "label": "Download App",
            "command": "openocd -f interface/cmsis-dap.cfg -f target/geehy/apm32f4x.cfg -c'program ./build/app.elf reset exit' ",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "dependsOn": ["Build App"]
        }
    ]
}