{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "./build/${workspaceFolderBasename}.elf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "openocd",
            "gdbPath": "arm-none-eabi-gdb.exe",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/geehy/apm32f4x.cfg",
            ],
            "svdFile": ".vscode/APM32F40x.svd",
            "preLaunchTask": "Build",
        },
        {
            "name": "attach",
            "cwd": "${workspaceFolder}",
            "executable": "./build/${workspaceFolderBasename}.elf",
            "request": "attach",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "openocd",
            "gdbPath": "arm-none-eabi-gdb.exe",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/geehy/apm32f4x.cfg",
            ],
            "svdFile": ".vscode/APM32F40x.svd"
        },
    ]
}